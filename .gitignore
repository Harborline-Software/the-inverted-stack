# Source papers (raw research material - not committed to public repo)
source/

# Build output
build/output/
*.pdf
*.epub
*.docx

# Editor temp files
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Local overrides
.env
.env.local

# Pandoc intermediate
*.tex
*.aux
*.log
*.toc

# Python bytecode cache
__pycache__/
*.pyc

# Voice-pass drafts (regenerable; review and merge selectively)
vol-2/_voice-drafts/

# OpenWolf runtime state (regenerated by `openwolf scan`)
.wolf/anatomy.md
.wolf/_archive/
.wolf/memory.md
.wolf/scheduled_tasks.lock
.wolf/hooks/_session.json
.wolf/token-ledger.json
.wolf/backups/
.wolf/designqc-captures/

# Claude Code per-session runtime
.claude/scheduled_tasks.lock
.claude/hooks/
.claude/worktrees/
.claude/settings.local.json

# Galley platform working state inside vol-2 (canonical galley root lives
# under ../galley/build/<book-id>/ per architectural decision 2026-05-08;
# this directory is local working state that should not be committed)
vol-2/.galley/

# Web reader build artifacts
web/node_modules/
web/dist/
web/package-lock.json

# Prose-telemetry reference corpora (copyrighted source texts; not committed)
corpora/

# Vale config - generated, can be regenerated via prose_telemetry_vale_export.py
.vale/styles/

# Git worktrees — must live under .worktrees/ per fleet convention
.worktrees/

# OpenWolf additional runtime state
.wolf/cron-state.json
