# direnv configuration for the-inverted-stack
#
# direnv auto-loads this file when you `cd` into the repo, exporting any
# environment variables defined here (or in .env via the `dotenv` builtin)
# into the current shell. This gives Python scripts, the Makefile, and any
# other tooling consistent access to TTS_API_KEY and friends without
# requiring them to be set in ~/.zshrc.
#
# First-time setup:
#   1. brew install direnv                     (already installed if you're reading this)
#   2. Add to ~/.zshrc:  eval "$(direnv hook zsh)"
#   3. Restart your shell (or `source ~/.zshrc`)
#   4. cd into this repo and run:  direnv allow
#
# After that, every `cd` into the repo auto-loads .env and exports TTS_API_KEY
# (and anything else .env declares) into your shell. Direct `python3 ...`
# invocations now see the same env that `make` targets do.

# Load .env if present (gitignored; copy from .env.example to create it).
# direnv's `dotenv` builtin handles quoting, comments, and blank lines
# correctly - more forgiving than Make's raw -include.
if [ -f .env ]; then
  dotenv
fi

# Non-secret repo-local defaults can go here directly. They override anything
# inherited from the parent shell and are visible to every process spawned
# inside the repo.

# Pin the Galley book ID so audiobook.py / imagegen.py route artifacts under
# galley/build/the-inverted-stack/ by default. Override per-session if needed.
export GALLEY_BOOK_ID="${GALLEY_BOOK_ID:-the-inverted-stack}"
